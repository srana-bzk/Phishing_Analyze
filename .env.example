# ── VirusTotal ────────────────────────────────────────────────
# Get a free key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Qwen / DashScope (optional — only needed for cloud Qwen) ──
# Get a key at: https://dashscope.aliyuncs.com
# Leave blank if using local Ollama instead
QWEN_API_KEY=

# ── Ollama (local AI — default settings) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TEXT_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=gemma3:4b
